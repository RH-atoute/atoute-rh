# ─── BASE DE DONNÉES ───────────────────────────────────────────
# Copiez l'URL fournie par Railway après création du service PostgreSQL
DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DATABASE

# ─── JWT ───────────────────────────────────────────────────────
# Chaîne aléatoire longue — ex: openssl rand -hex 64
JWT_SECRET=CHANGEZ_MOI_AVEC_UNE_LONGUE_CHAINE_ALEATOIRE
JWT_EXPIRES_IN=7d

# ─── RESEND (emails) ───────────────────────────────────────────
# Créez un compte sur resend.com puis API Keys → Create API Key
RESEND_API_KEY=re_VOTRE_CLE_API
RESEND_FROM=noreply@atoute.fr

# ─── APPLICATION ───────────────────────────────────────────────
PORT=3000
NODE_ENV=production
FRONTEND_URL=https://votre-app.railway.app

# ─── UPLOADS ───────────────────────────────────────────────────
MAX_FILE_SIZE_MB=10
UPLOAD_PATH=./uploads
